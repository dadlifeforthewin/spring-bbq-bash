# === Supabase (from your Supabase project Settings > API) ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# === Admin / Volunteer Gate ===
# Simple shared password for the admin + zone stations.
# Pick something unguessable like: bbq-2026-pink-cow-42
ADMIN_PASSWORD=change-me-please

# === ntfy.sh ===
# Long random prefix for ntfy topics so nobody can guess them.
# Generate with: openssl rand -hex 12
NTFY_TOPIC_PREFIX=sbbq-CHANGE-ME-xxxxxxxx

# === Public site URL (used by ntfy deep-links and QR codes) ===
# On Vercel this is auto-populated, but set it explicitly for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
